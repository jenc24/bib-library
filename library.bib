@article{kamenikEulerEulerNumerical2025,
  title = {Euler–{{Euler Numerical Model}} for {{Transport Phenomena Modeling}} in a {{Natural Circulation Loop Operated}} by {{Nanofluids}}},
  author = {Kamenik, Blaž and Vovk, Nejc and Elcioglu, Elif Begum and Sezgin, Firat and Ozyurt, Erdem and Karadeniz, Ziya Haktan and Turgut, Alpaslan and Ravnik, Jure},
