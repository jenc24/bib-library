@article{fornariClusteringIncreasedSettling2018,
  title = {Clustering and {{Increased Settling Speed}} of {{Oblate Particles}} at {{Finite Reynolds Number}}},
  author = {Fornari, Walter and Ardekani, Mehdi Niazi and Brandt, Luca},
  date = {2018-08},
  journaltitle = {Journal of Fluid Mechanics},
  volume = {848},
  pages = {696--721},
  issn = {0022-1120, 1469-7645},
  doi = {10.1017/jfm.2018.370},
  abstract = {We study the settling of rigid oblates in a quiescent fluid using interface-resolved direct numerical simulations. In particular, an immersed boundary method is used to account for the dispersed solid phase together with lubrication correction and collision models to account for short-range particle–particle interactions. We consider semi-dilute suspensions of oblate particles with aspect ratio \textbackslash AR=1/3\textbackslash{} and solid volume fractions \textbackslash textbackslash unicode[STIX]\textbackslash textbraceleft x1D719\textbackslash textbraceright =0.5\textbackslash textbraceleft -\textbackslash textbraceright 10\textbackslash textbackslash,\textbackslash textbackslash\%\textbackslash{} . The solid-to-fluid density ratio \textbackslash R=1.02\textbackslash{} and the Galileo number (i.e. the ratio between buoyancy and viscous forces) based on the diameter of a sphere with equivalent volume \textbackslash Ga=60\textbackslash{} . With this choice of parameters, an isolated oblate falls vertically with a steady wake with its broad side perpendicular to the gravity direction. At this \textbackslash Ga\textbackslash{} , the mean settling speed of spheres is a decreasing function of the volume \textbackslash textbackslash unicode[STIX]\textbackslash textbraceleft x1D719\textbackslash textbraceright\textbackslash{} and is always smaller than the terminal velocity of the isolated particle, \textbackslash V\_\textbackslash textbraceleft t\textbackslash textbraceright\textbackslash{} . On the contrary, in dilute suspensions of oblate particles (with \textbackslash textbackslash unicode[STIX]\textbackslash textbraceleft x1D719\textbackslash textbraceright\textbackslash textbackslash leqslant 1\textbackslash textbackslash,\textbackslash textbackslash\%\textbackslash{} ), the mean settling speed is approximately 33 \% larger than \textbackslash V\_\textbackslash textbraceleft t\textbackslash textbraceright\textbackslash{} . At higher concentrations, the mean settling speed decreases becoming smaller than the terminal velocity \textbackslash V\_\textbackslash textbraceleft t\textbackslash textbraceright\textbackslash{} between \textbackslash textbackslash unicode[STIX]\textbackslash textbraceleft x1D719\textbackslash textbraceright =5\textbackslash textbackslash,\textbackslash textbackslash\%\textbackslash{} and 10 \%. The increase of the mean settling speed is due to the formation of particle clusters that for \textbackslash textbackslash unicode[STIX]\textbackslash textbraceleft x1D719\textbackslash textbraceright =0.5\textbackslash textbraceleft -\textbackslash textbraceright 1\textbackslash textbackslash,\textbackslash textbackslash\%\textbackslash{} appear as columnar-like structures. From the pair distribution function we observe that it is most probable to find particle pairs almost vertically aligned. However, the pair distribution function is non-negligible all around the reference particle indicating that there is a substantial amount of clustering at radial distances between 2 and \textbackslash 6c\textbackslash{} (with \textbackslash c\textbackslash{} the polar radius of the oblate). Above \textbackslash textbackslash unicode[STIX]\textbackslash textbraceleft x1D719\textbackslash textbraceright =5\textbackslash textbackslash,\textbackslash textbackslash\%\textbackslash{} , the hindrance becomes the dominant effect, and the mean settling speed decreases below \textbackslash V\_\textbackslash textbraceleft t\textbackslash textbraceright\textbackslash{} . As the particle concentration increases, the mean particle orientation changes and the mean pitch angle (the angle between the particle axis of symmetry and gravity) increases from \textbackslash 23ˆ\textbackslash textbraceleft\textbackslash textbackslash circ \textbackslash textbraceright\textbackslash{} to \textbackslash 47ˆ\textbackslash textbraceleft\textbackslash textbackslash circ \textbackslash textbraceright\textbackslash{} . Finally, we increase \textbackslash Ga\textbackslash{} from 60 to 140 for the case with \textbackslash textbackslash unicode[STIX]\textbackslash textbraceleft x1D719\textbackslash textbraceright =0.5\textbackslash textbackslash,\textbackslash textbackslash\%\textbackslash{} and find that the mean settling speed (normalized by \textbackslash V\_\textbackslash textbraceleft t\textbackslash textbraceright\textbackslash{} ) decreases by less than 1 \% with respect to \textbackslash Ga=60\textbackslash{} . However, the fluctuations of the settling speed around the mean are reduced and the probability of finding vertically aligned particle pairs increases.},
  file = {/home/nejcv/Zotero/storage/QSSJNQ8J/Fornari et al. - 2018 - Clustering and increased settling speed of oblate particles at finite Reynolds number.pdf}
}

@article{fortesNonlinearMechanicsFluidization1987,
  title = {Nonlinear {{Mechanics}} of {{Fluidization}} of {{Beds}} of {{Spherical Particles}}},
  author = {Fortes, A. F. and Joseph, D. D. and Lundgren, T. S.},
  date = {1987-04},
  journaltitle = {Journal of Fluid Mechanics},
  volume = {177},
  pages = {467--483},
  issn = {0022-1120, 1469-7645},
  doi = {10.1017/S0022112087001046},
  abstract = {Experiments on fluidization with water of spherical particles falling against gravity in columns of rectangular cross-section are described. All of them are dominated by inertial effects associated with wakes. Two local mechanisms are involved: drafting and kissing and tumbling into stable cross-stream arrays. Drafting, kissing and tumbling are rearrangement mechanisms in which one sphere is captured in the wake of the other. The kissing spheres are aligned with the stream. The streamwise alignment is massively unstable and the kissing spheres tumble into more stable cross-stream pairs of doublets which can aggregate into larger relatively stable horizontal arrays. Cross-stream arrays in beds of spheres constrained to move in two dimensions are remarkable. These arrays may even coalesce into aggregations of close-packed spheres separated by regions of clear water. A somewhat weaker form of cooperative motion of cross-stream arrays of rising spheres is found in beds of square cross-section where the spheres may move freely in three dimensions. Horizontal arrays rise where drafting spheres fall because of greater drag. Aggregation of spheres seems to be associated with relatively stable cooperative motions of horizontal arrays of spheres rising in their own wakes.}
}

