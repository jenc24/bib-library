@article{hoqueCriticalAnalysisTurbulence2024,
  title = {A {{Critical Analysis}} of {{Turbulence Modulation}} in {{Particulate Flow Systems}}: {{A Review}} of the {{Experimental Studies}}},
  shorttitle = {A {{Critical Analysis}} of {{Turbulence Modulation}} in {{Particulate Flow Systems}}},
  author = {Hoque, Mohammad Mainul and Joshi, Jyeshtharaj B. and Evans, Geoffrey M. and Mitra, Subhasish},
